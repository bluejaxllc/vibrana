# ─── Vibrana Backend Environment Variables ───
# Copy this to .env and fill in real values

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_ENV=development

# JWT Authentication
JWT_SECRET=change-me-to-a-long-random-string

# Database (leave empty for SQLite, set for PostgreSQL in cloud)
DATABASE_URL=

# CORS (comma-separated origins; leave empty for defaults)
CORS_ORIGINS=

# License Server
LICENSE_SERVER_URL=https://vibrana-license-server-production.up.railway.app

# GoHighLevel Integration
GHL_API_TOKEN=
GHL_LOCATION_ID=GC3Q5eqwDKw2MhZQ0KSj
GHL_TEST_PHONE=

# AI / Gemini (optional, for AI interpretations)
GEMINI_API_KEY=

# Session file for GHL token interception (local only)
GHL_SESSION_FILE=
